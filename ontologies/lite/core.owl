            <rdf:Description rdf:about="https://orbis-security.com/maeco#File"/>
            <rdf:Description rdf:about="https://orbis-security.com/maeco#Process"/>
            <rdf:Description rdf:about="https://orbis-security.com/maeco#Technique"/>
            <rdf:Description rdf:about="https://orbis-security.com/maeco#WindowsRegistryKey"/>
        </members>
    </rdf:Description>
</rdf:RDF>



