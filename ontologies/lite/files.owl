    <!-- http://purl.org/orbis-security/maeco-lite#ApplicationDataOrConfigFile -->

    <Class rdf:about="http://purl.org/orbis-security/maeco-lite#ApplicationDataOrConfigFile">
        <rdfs:subClassOf rdf:resource="http://purl.org/orbis-security/maeco-lite#ApplicationFile"/>
        <rdfs:comment>A file storing application data, configuration, logs, or caches shared accross all users, found in the \ProgramData directory.</rdfs:comment>
        <rdfs:label>Application Data Or Config File</rdfs:label>
    </Class>
    


    <!-- http://purl.org/orbis-security/maeco-lite#ApplicationFile -->

    <Class rdf:about="http://purl.org/orbis-security/maeco-lite#ApplicationFile">
        <rdfs:subClassOf rdf:resource="http://purl.org/orbis-security/maeco-lite#File"/>
        <rdfs:comment>A file that is a part of a application found in the \Program Files, \Program Files (x86), or \ProgramData directory.</rdfs:comment>
        <rdfs:label>Application File</rdfs:label>
    </Class>
    


    <!-- http://purl.org/orbis-security/maeco-lite#ApplicationProgramFile -->

