    <!-- https://orbis-security.com/maeco#ApplicationDataOrConfigFile -->

    <Class rdf:about="https://orbis-security.com/maeco#ApplicationDataOrConfigFile">
        <rdfs:subClassOf rdf:resource="https://orbis-security.com/maeco#ApplicationFile"/>
        <rdfs:comment>A file storing application data, configuration, logs, or caches shared accross all users, found in the \ProgramData directory.</rdfs:comment>
        <rdfs:label>Application Data Or Config File</rdfs:label>
    </Class>
    


    <!-- https://orbis-security.com/maeco#ApplicationFile -->

