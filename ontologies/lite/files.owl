    </Class>
    


    <!-- http://purl.org/orbis-security/maeco-lite#SystemCoreFile -->

    <Class rdf:about="http://purl.org/orbis-security/maeco-lite#SystemCoreFile">
        <rdfs:subClassOf rdf:resource="http://purl.org/orbis-security/maeco-lite#SystemFile"/>
        <rdfs:comment>A core system file (executable, library, driver, etc.) critical for its functionality found in the \Windows directory.</rdfs:comment>
        <rdfs:label>System Core File</rdfs:label>
    </Class>
    


    <!-- http://purl.org/orbis-security/maeco-lite#SystemFile -->

    <Class rdf:about="http://purl.org/orbis-security/maeco-lite#SystemFile">
