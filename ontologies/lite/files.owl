        <rdfs:subClassOf rdf:resource="http://purl.org/orbis-security/maeco-lite#File"/>
        <rdfs:comment>A file that can be used to achieve malware persistence, such as a scheduled task definition or a shell module.</rdfs:comment>
        <rdfs:label>Persistence File</rdfs:label>
    </Class>
    


